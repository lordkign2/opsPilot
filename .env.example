# ============================================================
# OpsPilot Backend — Environment Configuration
# ============================================================
# Copy this file to `.env` and fill in your values.

# ─── Application ─────────────────────────────────────────────
APP_NAME=OpsPilot
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# ─── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://opspilot:opspilot_secret@localhost:5432/opspilot_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── OpenAI (Phase 3) ───────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ─── Paystack (Phase 2) ─────────────────────────────────────
# PAYSTACK_SECRET_KEY=sk_test_...
# PAYSTACK_PUBLIC_KEY=pk_test_...

# ─── Observability (Phase 7) ────────────────────────────────
# Sentry error tracking — leave blank to disable (safe for local dev)
# SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production

# Prometheus metrics (enabled by default)
PROMETHEUS_ENABLED=true

# Optional bearer token to protect /metrics endpoint in staging environments
# METRICS_SECRET=your-secret-token-here

# Grafana credentials (used by docker-compose)
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=opspilot

